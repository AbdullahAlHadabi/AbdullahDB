SELECT COUNT(EMPLOYEE_ID) AS "Total Employees"
FROM HR.EMPLOYEES;

SELECT COUNT(DEPARTMENT_ID) AS "Total Departments"
FROM HR.DEPARTMENTS;


SELECT SUM(SALARY) AS "Total Salary Bill"
FROM HR.EMPLOYEES;

SELECT SUM(COMMISSION_PCT) AS "Total Commission % "
FROM HR.EMPLOYEES;


SELECT AVG(SALARY) AS "Average Salary"
FROM HR.EMPLOYEES;

SELECT AVG(MIN_SALARY) AS "Avg of Min Salaries", AVG(MAX_SALARY) AS "Avg of Max Salaries"
FROM HR.JOBS;

SELECT MAX(MAX_SALARY) AS "Global Max Salary", MIN(MAX_SALARY) AS "Global Min of Max Salaries"
FROM HR.JOBS;


SELECT D.DEPARTMENT_NAME, COUNT(E.EMPLOYEE_ID) AS "Number of Employees"
FROM HR.EMPLOYEES E, HR.DEPARTMENTS D
WHERE E.DEPARTMENT_ID = D.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME
ORDER BY D.DEPARTMENT_NAME;

SELECT JOB_TITLE,
 AVG(MIN_SALARY) AS "Avg Min Salary",
 AVG(MAX_SALARY) AS "Avg Max Salary"
FROM HR.JOBS
GROUP BY JOB_TITLE
ORDER BY JOB_TITLE;

SELECT D.DEPARTMENT_NAME, COUNT(E.EMPLOYEE_ID) AS "Number of Employees"
FROM HR.EMPLOYEES E, HR.DEPARTMENTS D
WHERE E.DEPARTMENT_ID = D.DEPARTMENT_ID
GROUP BY D.DEPARTMENT_NAME
HAVING COUNT(E.EMPLOYEE_ID) > 5;


SELECT JOB_TITLE, AVG(MAX_SALARY) AS "Average Max Salary"
FROM HR.JOBS
GROUP BY JOB_TITLE
HAVING AVG(MAX_SALARY) > 15000;